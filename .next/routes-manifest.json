    },
    {
      "page": "/sections/FeatureSpotlightSection",
      "regex": "^/sections/FeatureSpotlightSection(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sections/FeatureSpotlightSection(?:/)?$"
    },
    {
      "page": "/sections/HeroShowcaseSection",
      "regex": "^/sections/HeroShowcaseSection(?:/)?$",
      "routeKeys": {},
